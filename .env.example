# Supabase (auth + cloud sync)
# Get these from: https://supabase.com/dashboard → Your project → Project Settings → API
#
# NUXT_PUBLIC_SUPABASE_URL = Project URL (e.g. https://xxxx.supabase.co)
# NUXT_PUBLIC_SUPABASE_ANON_KEY = anon / public key (safe for browser; still use RLS)
#
# বাংলা: উপরের দুটি মান Supabase ড্যাশবোর্ড থেকে কপি করে `.env` ফাইলে বসান।

NUXT_PUBLIC_SUPABASE_URL=
NUXT_PUBLIC_SUPABASE_ANON_KEY=
